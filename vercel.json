{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/site-sitemap"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/site-robots"
    },
    {
      "source": "/:file(google[a-z0-9]+\\.html)",
      "destination": "/api/google-html?file=:file"
    },
    {
      "source": "/:file(google[a-z0-9]+)",
      "destination": "/api/google-html?file=:file.html"
    },
    {
      "source": "/api/((?!google-html$|site-sitemap$|site-robots$).*)",
      "destination": "https://api.bizuply.com/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate, no-transform" },
        { "key": "Vary", "value": "Accept-Encoding" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        { "key": "Content-Type", "value": "image/x-icon" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}
